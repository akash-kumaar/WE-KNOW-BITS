<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AMRx — AI Antimicrobial Resistance Assistant</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>

<style>
:root {
  --bg: #0d0f14;
  --bg2: #13161e;
  --bg3: #1a1e28;
  --bg4: #222736;
  --border: rgba(255,255,255,0.07);
  --border2: rgba(255,255,255,0.12);
  --text: #e8eaf0;
  --text2: #8b91a8;
  --text3: #555d78;
  --accent: #00e5a0;
  --accent2: #00b87d;
  --accent-dim: rgba(0,229,160,0.1);
  --accent-glow: rgba(0,229,160,0.2);
  --red: #ff5c5c;
  --red-dim: rgba(255,92,92,0.12);
  --amber: #ffb347;
  --amber-dim: rgba(255,179,71,0.12);
  --blue: #4da6ff;
  --blue-dim: rgba(77,166,255,0.12);
  --sidebar-w: 260px;
  --radius: 12px;
  --radius-sm: 8px;
  --font: 'Sora', sans-serif;
  --mono: 'JetBrains Mono', monospace;

  --lt-bg: #f3f4f7;
  --lt-surface: #ffffff;
  --lt-border: #e2e6ed;
  --lt-text: #1a1d2e;
  --lt-text2: #5a6278;
  --lt-text3: #9aa0b4;
  --lt-accent: #2563eb;
  --lt-accent-dim: rgba(37,99,235,0.08);
  --lt-red: #dc2626;
  --lt-amber: #d97706;
  --lt-shadow: 0 2px 12px rgba(0,0,0,0.07);
  --lt-shadow-md: 0 4px 24px rgba(0,0,0,0.10);
}

* { margin:0; padding:0; box-sizing:border-box; }

body {
  font-family: var(--font);
  background: var(--lt-bg);
  color: var(--lt-text);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  overflow-x: hidden;
}

.topnav {
  background: var(--lt-surface);
  border-bottom: 1px solid var(--lt-border);
  height: 56px;
  display: flex;
  align-items: center;
  padding: 0 32px;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 1px 8px rgba(0,0,0,0.06);
  flex-shrink: 0;
}

.topnav-logo {
  display: flex;
  align-items: center;
  gap: 8px;
  text-decoration: none;
  margin-right: auto;
}

.topnav-logo-icon {
  width: 28px; height: 28px;
  background: var(--lt-accent);
  border-radius: 7px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}

.topnav-logo-icon svg { width: 15px; height: 15px; }

.topnav-logo-text {
  font-size: 18px;
  font-weight: 700;
  color: var(--lt-text);
  letter-spacing: -0.5px;
}

.topnav-logo-text span { color: var(--lt-accent); }

.topnav-links {
  display: flex;
  align-items: center;
  gap: 4px;
}

.topnav-link {
  padding: 7px 16px;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 500;
  color: var(--lt-text2);
  cursor: pointer;
  transition: all 0.15s;
  border: none;
  background: none;
  font-family: var(--font);
  text-decoration: none;
}

.topnav-link:hover { background: var(--lt-accent-dim); color: var(--lt-text); }
.topnav-link.active { color: var(--lt-accent); font-weight: 600; }

.page-wrapper {
  flex: 1;
  overflow-y: auto;
  padding-bottom: 56px;
}

.page-wrapper::-webkit-scrollbar { width: 5px; }
.page-wrapper::-webkit-scrollbar-thumb { background: #d0d4de; border-radius: 4px; }

.page { display: none; }
.page.active { display: block; }

.analyze-layout {
  max-width: 1200px;
  margin: 0 auto;
  padding: 36px 32px 24px;
  display: grid;
  grid-template-columns: 1fr 360px;
  gap: 28px;
  align-items: start;
}
</style>
