<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AMRx — AI Antimicrobial Resistance Assistant</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
  /* ─── ORIGINAL CSS VARS (kept for JS compatibility) ─── */
  :root {
    --bg: #0d0f14;
    --bg2: #13161e;
    --bg3: #1a1e28;
    --bg4: #222736;
    --border: rgba(255,255,255,0.07);
    --border2: rgba(255,255,255,0.12);
    --text: #e8eaf0;
    --text2: #8b91a8;
    --text3: #555d78;
    --accent: #00e5a0;
    --accent2: #00b87d;
    --accent-dim: rgba(0,229,160,0.1);
    --accent-glow: rgba(0,229,160,0.2);
    --red: #ff5c5c;
    --red-dim: rgba(255,92,92,0.12);
    --amber: #ffb347;
    --amber-dim: rgba(255,179,71,0.12);
    --blue: #4da6ff;
    --blue-dim: rgba(77,166,255,0.12);
    --sidebar-w: 260px;
    --radius: 12px;
    --radius-sm: 8px;
    --font: 'Sora', sans-serif;
    --mono: 'JetBrains Mono', monospace;

    /* ─── NEW LIGHT THEME VARS ─── */
    --lt-bg: #f3f4f7;
    --lt-surface: #ffffff;
    --lt-border: #e2e6ed;
    --lt-text: #1a1d2e;
    --lt-text2: #5a6278;
    --lt-text3: #9aa0b4;
    --lt-accent: #2563eb;
    --lt-accent-dim: rgba(37,99,235,0.08);
    --lt-red: #dc2626;
    --lt-amber: #d97706;
    --lt-shadow: 0 2px 12px rgba(0,0,0,0.07);
    --lt-shadow-md: 0 4px 24px rgba(0,0,0,0.10);
  }

  * { margin:0; padding:0; box-sizing:border-box; }

  /* ─── RESET BODY TO LIGHT ─── */
  body {
    font-family: var(--font);
    background: var(--lt-bg);
    color: var(--lt-text);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
  }

  /* ═══════════════════════════════
     TOP NAVBAR
  ═══════════════════════════════ */
  .topnav {
    background: var(--lt-surface);
    border-bottom: 1px solid var(--lt-border);
    height: 56px;
    display: flex;
    align-items: center;
    padding: 0 32px;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 1px 8px rgba(0,0,0,0.06);
    flex-shrink: 0;
  }
  .topnav-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    margin-right: auto;
  }
  .topnav-logo-icon {
    width: 28px; height: 28px;
    background: var(--lt-accent);
    border-radius: 7px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .topnav-logo-icon svg { width: 15px; height: 15px; }
  .topnav-logo-text {
    font-size: 18px;
    font-weight: 700;
    color: var(--lt-text);
    letter-spacing: -0.5px;
  }
  .topnav-logo-text span { color: var(--lt-accent); }
  .topnav-links {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .topnav-link {
    padding: 7px 16px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    color: var(--lt-text2);
    cursor: pointer;
    transition: all 0.15s;
    border: none;
    background: none;
    font-family: var(--font);
    text-decoration: none;
  }
  .topnav-link:hover { background: var(--lt-accent-dim); color: var(--lt-text); }
  .topnav-link.active { color: var(--lt-accent); font-weight: 600; }

  /* ═══════════════════════════════
     PAGE WRAPPER
  ═══════════════════════════════ */
  .page-wrapper {
    flex: 1;
    overflow-y: auto;
    padding-bottom: 56px; /* space for fixed disclaimer */
  }
  .page-wrapper::-webkit-scrollbar { width: 5px; }
  .page-wrapper::-webkit-scrollbar-thumb { background: #d0d4de; border-radius: 4px; }

  /* ─── PAGE VISIBILITY ─── */
  .page { display: none; }
  .page.active { display: block; }

  /* ═══════════════════════════════
     ANALYZE PAGE (CHAT + SYMPTOMS merged into main)
  ═══════════════════════════════ */
  .analyze-layout {
    max-width: 1200px;
    margin: 0 auto;
    padding: 36px 32px 24px;
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 28px;
    align-items: start;
  }

  /* LEFT PANEL */
  .left-panel {}
  .left-panel h1 {
    font-size: 26px;
    font-weight: 700;
    color: var(--lt-text);
    letter-spacing: -0.5px;
    margin-bottom: 8px;
    line-height: 1.25;
  }
  .left-panel .subtitle {
    font-size: 14px;
    color: var(--lt-text2);
    margin-bottom: 24px;
    line-height: 1.6;
  }

  /* CARD BASE */
  .lt-card {
    background: var(--lt-surface);
    border: 1px solid var(--lt-border);
    border-radius: 14px;
    box-shadow: var(--lt-shadow);
    margin-bottom: 16px;
    overflow: hidden;
  }
  .lt-card-body { padding: 20px 22px; }

  /* REGION CARD */
  .region-card .lt-card-body { padding: 20px 22px; }
  .field-label {
    font-size: 12px;
    font-weight: 600;
    color: var(--lt-text2);
    margin-bottom: 8px;
    letter-spacing: 0.3px;
  }
  .region-select-wrap {
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--lt-bg);
    border: 1px solid var(--lt-border);
    border-radius: 10px;
    padding: 10px 14px;
  }
  .region-select-wrap svg { color: var(--lt-text3); flex-shrink: 0; }
  .region-select-wrap select {
    background: none;
    border: none;
    outline: none;
    font-family: var(--font);
    font-size: 14px;
    color: var(--lt-text);
    width: 100%;
    cursor: pointer;
    -webkit-appearance: none;
    appearance: none;
  }

  /* UPLOAD CARD */
  .upload-card {}
  .upload-drop-zone {
    margin: 20px 22px 0;
    border: 2px dashed var(--lt-border);
    border-radius: 12px;
    padding: 40px 24px;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    background: var(--lt-bg);
  }
  .upload-drop-zone:hover { border-color: var(--lt-accent); background: var(--lt-accent-dim); }
  .upload-icon-wrap {
    width: 48px; height: 48px;
    margin: 0 auto 16px;
    display: flex; align-items: center; justify-content: center;
    color: var(--lt-accent);
  }
  .upload-drop-zone h3 { font-size: 15px; font-weight: 600; color: var(--lt-text); margin-bottom: 6px; }
  .upload-drop-zone p { font-size: 13px; color: var(--lt-text2); margin-bottom: 4px; }
  .upload-drop-zone small { font-size: 12px; color: var(--lt-text3); }

  /* CHAT INPUT (inside upload card) */
  .chat-input-section { padding: 16px 22px 20px; }
  .chat-input-box {
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--lt-bg);
    border: 1px solid var(--lt-border);
    border-radius: 10px;
    padding: 10px 14px;
    transition: border-color 0.2s;
  }
  .chat-input-box:focus-within { border-color: var(--lt-accent); }
  .chat-input-box textarea {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: var(--font);
    font-size: 14px;
    color: var(--lt-text);
    resize: none;
    min-height: 22px;
    max-height: 100px;
    line-height: 1.5;
  }
  .chat-input-box textarea::placeholder { color: var(--lt-text3); }
  .chat-send-btn {
    width: 32px; height: 32px;
    background: var(--lt-accent);
    border: none;
    border-radius: 8px;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    color: #fff;
    transition: background 0.15s, transform 0.1s;
    flex-shrink: 0;
  }
  .chat-send-btn:hover { background: #1d4ed8; transform: scale(1.04); }
  .chat-attach-btn {
    width: 32px; height: 32px;
    background: none;
    border: 1px solid var(--lt-border);
    border-radius: 8px;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    color: var(--lt-text2);
    transition: all 0.15s;
    flex-shrink: 0;
  }
  .chat-attach-btn:hover { background: var(--lt-accent-dim); color: var(--lt-accent); }

  /* FILE PREVIEW */
  .file-preview-lt {
    display: flex; align-items: center; gap: 8px;
    background: var(--lt-accent-dim);
    border: 1px solid rgba(37,99,235,0.15);
    border-radius: 8px; padding: 7px 12px;
    font-size: 12px; color: var(--lt-text2);
    margin: 0 22px 8px;
  }
  .file-preview-lt .remove { cursor: pointer; color: var(--lt-text3); margin-left: auto; }
  .file-preview-lt .remove:hover { color: var(--lt-red); }

  /* CHAT RESPONSE AREA */
  .chat-response-area {
    margin-top: 8px;
  }
  .chat-welcome-lt {
    padding: 28px 22px;
    text-align: center;
  }
  .chat-welcome-lt p { font-size: 13px; color: var(--lt-text3); }
  .quick-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-top: 16px;
    text-align: left;
  }
  .quick-card-lt {
    background: var(--lt-bg);
    border: 1px solid var(--lt-border);
    border-radius: 10px;
    padding: 12px 14px;
    cursor: pointer;
    transition: all 0.15s;
    font-size: 12px;
    color: var(--lt-text2);
    line-height: 1.5;
  }
  .quick-card-lt:hover { border-color: var(--lt-accent); color: var(--lt-text); box-shadow: 0 2px 8px rgba(37,99,235,0.08); }
  .quick-card-lt-title { font-size: 12px; font-weight: 600; color: var(--lt-text); margin-bottom: 3px; }

  /* CHAT MESSAGES */
  #chatMessages { padding: 0 22px 16px; }
  .lt-message { display: flex; gap: 10px; margin-bottom: 16px; }
  .lt-message.user { flex-direction: row-reverse; }
  .lt-avatar {
    width: 30px; height: 30px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 700; flex-shrink: 0;
  }
  .lt-avatar.ai { background: var(--lt-accent-dim); color: var(--lt-accent); border: 1px solid rgba(37,99,235,0.15); font-size: 10px; }
  .lt-avatar.user { background: #f0f0f5; color: var(--lt-text2); }
  .lt-bubble {
    max-width: 80%;
    padding: 10px 14px;
    border-radius: 12px;
    font-size: 13.5px;
    line-height: 1.6;
  }
  .lt-message.ai .lt-bubble { background: var(--lt-bg); border: 1px solid var(--lt-border); border-top-left-radius: 3px; color: var(--lt-text); }
  .lt-message.user .lt-bubble { background: var(--lt-accent); border-top-right-radius: 3px; color: #fff; }

  /* LOADING */
  .lt-loading { display: flex; align-items: center; gap: 8px; padding: 10px 14px; background: var(--lt-bg); border: 1px solid var(--lt-border); border-radius: 12px; width: fit-content; }
  .dot-wave { display: flex; gap: 4px; }
  .dot-wave span { width: 5px; height: 5px; border-radius: 50%; background: var(--lt-accent); animation: wave 1.2s infinite; }
  .dot-wave span:nth-child(2) { animation-delay: 0.2s; }
  .dot-wave span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes wave { 0%,60%,100%{transform:translateY(0)} 30%{transform:translateY(-5px)} }
  .loading-text { font-size: 12px; color: var(--lt-text3); }

  /* AI RESULT CARD */
  .ai-result-card {
    background: var(--lt-surface);
    border: 1px solid var(--lt-border);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 14px;
    max-width: 100%;
    box-shadow: var(--lt-shadow);
  }
  .ai-result-header {
    padding: 10px 14px;
    border-bottom: 1px solid var(--lt-border);
    display: flex; align-items: center; gap: 7px;
    font-size: 11px; font-weight: 600; color: var(--lt-text2);
    font-family: var(--mono); text-transform: uppercase; letter-spacing: 0.5px;
    background: var(--lt-bg);
  }
  .ai-result-body { padding: 14px; }
  .lt-info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 12px; }
  .lt-info-item {
    background: var(--lt-bg);
    border: 1px solid var(--lt-border);
    border-radius: 8px;
    padding: 9px 11px;
  }
  .lt-info-label { font-size: 10px; color: var(--lt-text3); font-family: var(--mono); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 3px; }
  .lt-info-value { font-size: 13px; font-weight: 600; color: var(--lt-text); }
  .lt-section-label { font-size: 10px; color: var(--lt-text3); font-family: var(--mono); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 6px; margin-top: 12px; }
  .lt-section-label:first-child { margin-top: 0; }
  .lt-eval-row { display: flex; align-items: center; gap: 8px; }
  .lt-eval-badge { padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; font-family: var(--mono); }
  .lt-eval-badge.correct { background: rgba(22,163,74,0.1); color: #16a34a; border: 1px solid rgba(22,163,74,0.2); }
  .lt-eval-badge.incorrect { background: rgba(220,38,38,0.08); color: var(--lt-red); border: 1px solid rgba(220,38,38,0.15); }
  .lt-risk-badge { padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; font-family: var(--mono); }
  .lt-risk-badge.low { background: rgba(22,163,74,0.1); color: #16a34a; border: 1px solid rgba(22,163,74,0.2); }
  .lt-risk-badge.medium { background: rgba(217,119,6,0.1); color: #b45309; border: 1px solid rgba(217,119,6,0.2); }
  .lt-risk-badge.high { background: rgba(220,38,38,0.08); color: var(--lt-red); border: 1px solid rgba(220,38,38,0.15); }
  .lt-explanation { background: var(--lt-bg); border-left: 3px solid var(--lt-accent); border-radius: 0 8px 8px 0; padding: 10px 13px; font-size: 13px; color: var(--lt-text2); line-height: 1.7; margin-top: 10px; }
  .eval-note { font-size: 12px; color: var(--lt-text2); }

  /* ═══════════════════════════════
     RIGHT SIDEBAR
  ═══════════════════════════════ */
  .right-sidebar {}
  .sidebar-section-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--lt-text);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .sidebar-section-title svg { color: var(--lt-accent); }

  .amr-stat-card {
    background: var(--lt-surface);
    border: 1px solid var(--lt-border);
    border-radius: 12px;
    box-shadow: var(--lt-shadow);
    padding: 16px 18px;
    margin-bottom: 12px;
    border-left: 4px solid transparent;
    position: relative;
    overflow: hidden;
  }
  .amr-stat-card.red { border-left-color: var(--lt-red); }
  .amr-stat-card.amber { border-left-color: var(--lt-amber); }
  .amr-stat-card-loc {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 12px;
    color: var(--lt-text2);
    font-weight: 500;
    margin-bottom: 6px;
  }
  .amr-stat-num {
    font-size: 36px;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 8px;
    font-family: var(--mono);
  }
  .amr-stat-card.red .amr-stat-num { color: var(--lt-red); }
  .amr-stat-card.amber .amr-stat-num { color: var(--lt-amber); }
  .amr-stat-desc { font-size: 12.5px; color: var(--lt-text2); line-height: 1.6; }

  .amr-info-box {
    background: #eff6ff;
    border: 1px solid #bfdbfe;
    border-radius: 12px;
    padding: 16px 18px;
    box-shadow: var(--lt-shadow);
  }
  .amr-info-box-title { font-size: 13px; font-weight: 700; color: #1d4ed8; margin-bottom: 8px; }
  .amr-info-box p { font-size: 12.5px; color: #3b5998; line-height: 1.7; }

  /* ═══════════════════════════════
     SYMPTOMS PAGE
  ═══════════════════════════════ */
  .symptoms-layout {
    max-width: 760px;
    margin: 0 auto;
    padding: 36px 32px 24px;
  }
  .page-title-lt { font-size: 22px; font-weight: 700; color: var(--lt-text); margin-bottom: 6px; }
  .page-subtitle-lt { font-size: 14px; color: var(--lt-text2); margin-bottom: 24px; }

  .lt-form-card {
    background: var(--lt-surface);
    border: 1px solid var(--lt-border);
    border-radius: 14px;
    box-shadow: var(--lt-shadow);
    padding: 24px;
    margin-bottom: 20px;
  }
  .lt-form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .lt-form-group { display: flex; flex-direction: column; gap: 6px; }
  .lt-form-group.full { grid-column: 1/-1; }
  .lt-form-label { font-size: 11px; color: var(--lt-text2); font-family: var(--mono); text-transform: uppercase; letter-spacing: 1px; font-weight: 600; }
  .lt-form-input {
    background: var(--lt-bg);
    border: 1px solid var(--lt-border);
    border-radius: 9px;
    color: var(--lt-text);
    font-family: var(--font); font-size: 14px;
    padding: 10px 14px;
    outline: none; transition: border-color 0.15s;
    -webkit-appearance: none; appearance: none;
  }
  .lt-form-input:focus { border-color: var(--lt-accent); }
  .lt-form-input option { background: #fff; }
  .lt-radio-group { display: flex; gap: 8px; }
  .lt-radio-opt {
    flex: 1;
    background: var(--lt-bg);
    border: 1px solid var(--lt-border);
    border-radius: 9px;
    padding: 10px;
    text-align: center; cursor: pointer; font-size: 13px;
    color: var(--lt-text2); transition: all 0.15s;
    user-select: none;
  }
  .lt-radio-opt:hover { border-color: var(--lt-accent); color: var(--lt-text); }
  .lt-radio-opt.selected { background: var(--lt-accent-dim); border-color: rgba(37,99,235,0.3); color: var(--lt-accent); font-weight: 600; }

  .lt-analyze-btn {
    width: 100%; padding: 13px;
    background: var(--lt-accent); color: #fff;
    border: none; border-radius: 10px;
    font-family: var(--font); font-size: 14px; font-weight: 600;
    cursor: pointer; transition: all 0.15s;
    margin-top: 4px;
  }
  .lt-analyze-btn:hover { background: #1d4ed8; transform: translateY(-1px); }
  .lt-analyze-btn:active { transform: translateY(0); }

  /* Results */
  .results-section { display: none; }
  .results-section.visible { display: block; }
  .result-risk-card {
    border-radius: 12px; padding: 18px 22px; margin-bottom: 14px;
    border: 1px solid; display: flex; align-items: center; gap: 16px;
    box-shadow: var(--lt-shadow);
  }
  .result-risk-card.low { background: rgba(22,163,74,0.06); border-color: rgba(22,163,74,0.2); }
  .result-risk-card.medium { background: rgba(217,119,6,0.06); border-color: rgba(217,119,6,0.2); }
  .result-risk-card.high { background: rgba(220,38,38,0.06); border-color: rgba(220,38,38,0.2); }
  .risk-icon { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .result-risk-card.low .risk-icon { background: rgba(22,163,74,0.12); color: #16a34a; }
  .result-risk-card.medium .risk-icon { background: rgba(217,119,6,0.12); color: #b45309; }
  .result-risk-card.high .risk-icon { background: rgba(220,38,38,0.10); color: var(--lt-red); }
  .risk-info h3 { font-size: 15px; font-weight: 600; margin-bottom: 4px; color: var(--lt-text); }
  .risk-info p { font-size: 13px; color: var(--lt-text2); line-height: 1.6; }

  .lt-chart-card {
    background: var(--lt-surface);
    border: 1px solid var(--lt-border);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 14px;
    box-shadow: var(--lt-shadow);
  }
  .lt-chart-card h3 { font-size: 12px; font-family: var(--mono); color: var(--lt-text2); margin-bottom: 16px; text-transform: uppercase; letter-spacing: 0.5px; }
  .chart-wrap { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
  .chart-canvas-wrap { width: 160px; height: 160px; flex-shrink: 0; }
  .chart-legend { flex: 1; min-width: 150px; }
  .legend-item { display: flex; align-items: center; gap: 8px; margin-bottom: 9px; font-size: 12.5px; }
  .legend-dot { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; }
  .legend-label { color: var(--lt-text2); }
  .legend-val { margin-left: auto; font-family: var(--mono); font-size: 11px; color: var(--lt-text); font-weight: 600; }

  /* ═══════════════════════════════
     ABOUT PAGE
  ═══════════════════════════════ */
  .about-layout {
    max-width: 800px;
    margin: 0 auto;
    padding: 36px 32px 24px;
  }
  .about-hero {
