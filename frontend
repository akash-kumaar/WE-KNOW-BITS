<script>
// ── NAV ──
function showPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.topnav-link').forEach(n => n.classList.remove('active'));
  document.getElementById('page-' + id).classList.add('active');
  document.getElementById('nav-' + id).classList.add('active');
  document.querySelector('.page-wrapper').scrollTo({ top: 0 });
}

// ── CHAT ──
let uploadedFile = null;
let chartInstance = null;

function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 120) + 'px';
}
function handleKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
}
function insertQuick(text) {
  const input = document.getElementById('chatInput');
  input.value = text;
  autoResize(input);
  input.focus();
}
function handleFile(e) {
  const file = e.target.files[0];
  if (!file) return;
  uploadedFile = file;
  document.getElementById('fileName').textContent = file.name;
  document.getElementById('filePreviewArea').style.display = 'flex';
}
function clearFile() {
  uploadedFile = null;
  document.getElementById('filePreviewArea').style.display = 'none';
  document.getElementById('fileInput').value = '';
}

async function sendMessage(){
  const input = document.getElementById('chatInput');
  const text = input.value.trim();
  if (!text && !uploadedFile) return;

  document.getElementById('welcomeScreen').style.display = 'none';
  const container = document.getElementById('chatMessages');

  const userText = text || "Analyze this prescription";
  appendMessage(container, 'user', userText);

  input.value = '';
  input.style.height = 'auto';


  const loadingId = appendLoading(container);
  scrollChat();

  // --- THE FIX IS HERE ---
  setTimeout(async () => {
    document.getElementById(loadingId)?.remove();
    const response = await generateResponse(userText);
    clearFile();
    appendAICard(container, response);
    scrollChat();
  }, 1800 + Math.random() * 800);
}
function appendMessage(container, role, text) {
  const div = document.createElement('div');
  div.className = 'lt-message ' + role + ' fade-up';
  div.innerHTML = `
    <div class="lt-avatar ${role}">${role === 'ai' ? 'AI' : 'U'}</div>
    <div class="lt-bubble">${text}</div>`;
  container.appendChild(div);
}

function appendLoading(container) {
  const id = 'loading-' + Date.now();
  const div = document.createElement('div');
  div.className = 'lt-message ai fade-up';
  div.id = id;
  div.innerHTML = `
    <div class="lt-avatar ai">AI</div>
    <div class="lt-loading">
      <div class="dot-wave"><span></span><span></span><span></span></div>
      <span class="loading-text">Analyzing prescription...</span>
    </div>`;
  container.appendChild(div);
  return id;
}

function appendAICard(container, data) {
  const evalClass = data.evaluation === 'Correct' ? 'correct' : 'incorrect';
  const riskClass = data.risk.toLowerCase();
  const div = document.createElement('div');
  div.className = 'lt-message ai fade-up';
  div.innerHTML = `
    <div class="lt-avatar ai">AI</div>
    <div style="max-width:85%;flex:1">
      <div class="ai-result-card">
        <div class="ai-result-header">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2"><circle cx="12" cy="12" r="10"/></svg>
          Prescription Analysis Report
        </div>
        <div class="ai-result-body">
          <div class="lt-section-label">Extracted Information</div>
          <div class="lt-info-grid">
            <div class="lt-info-item"><div class="lt-info-label">Disease</div><div class="lt-info-value">${data.disease}</div></div>
            <div class="lt-info-item"><div class="lt-info-label">Antibiotic</div><div class="lt-info-value">${data.antibiotic}</div></div>
            <div class="lt-info-item"><div class="lt-info-label">Dosage</div><div class="lt-info-value">${data.dosage}</div></div>
            <div class="lt-info-item"><div class="lt-info-label">Duration</div><div class="lt-info-value">${data.duration}</div></div>
          </div>
          <div class="lt-section-label">Evaluation</div>
          <div class="lt-eval-row">
            <span class="lt-eval-badge ${evalClass}">${data.evaluation}</span>
            <span class="eval-note">${data.evalNote}</span>
          </div>
          <div class="lt-section-label">Resistance Risk</div>
          <div class="lt-eval-row">
            <span class="lt-risk-badge ${riskClass}">${data.risk} Risk</span>
            <span class="eval-note">${data.riskNote}</span>
          </div>
          <div class="lt-section-label">Clinical Explanation</div>
          <div class="lt-explanation">${data.explanation}</div>
        </div>
      </div>
    </div>`;
  container.appendChild(div);
}

function scrollChat() {
  const wrapper = document.querySelector('.page-wrapper');
  setTimeout(() => wrapper.scrollTo({ top: wrapper.scrollHeight, behavior: 'smooth' }), 50);
}

async function generateResponse(text) {
  try {
    // 1. Convert the uploaded image to Base64 so Python can read it
    let base64Image = "";
    if (uploadedFile) {
      base64Image = await new Promise((resolve) => {
        const reader = new FileReader();
        reader.onloadend = () => resolve(reader.result);
        reader.readAsDataURL(uploadedFile);
      });
    }

    // 2. Send the data safely to your Python Backend (app.py)
    const response = await fetch('http://localhost:5000/analyze', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        image: base64Image,
        text_query: text,
        age: 25, 
        symptom: "Fever" 
      })
    });

    const data = await response.json();

    if (data.status === "error") {
      throw new Error(data.message);
    }

    // 3. Map Python's response back to your UI
    return {
      disease: "Detected from Prescription",
      antibiotic: data.medicine || "Unknown",
      dosage: "As prescribed",
      duration: "Standard Course",
      evaluation: data.risk_level === "HIGH RISK" ? "Incorrect" : "Correct",
      evalNote: `WHO Category: ${data.category}`,
      risk: data.risk_level === "HIGH RISK" ? "High" : "Low",
      riskNote: "Calculated by Random Forest ML",
      explanation: `Our AI model has classified this drug as a **${data.category}** category antibiotic. Based on clinical data, this presents a ${data.risk_level.toLowerCase()} for developing antimicrobial resistance.`
    };

  } catch (error) {
    console.error("Backend Error:", error);
    return {
      disease: "Error", antibiotic: "Error", dosage: "Error", duration: "Error",
      evaluation: "Error", evalNote: "Connection failed", risk: "High",
      riskNote: "Server Offline",
      explanation: "Could not connect to the Python Brain. Make sure you are running 'py app.py' in your terminal!"
    };
  }
}

// ── SYMPTOMS ──
let rxSelected = 'yes';
function selectRx(val) {
  rxSelected = val;
  document.getElementById('rx-yes').classList.toggle('selected', val === 'yes');
  document.getElementById('rx-no').classList.toggle('selected', val === 'no');
}

function runSymptomAnalysis() {
  const disease = document.getElementById('symp-disease').value.trim();
  const antibiotic = document.getElementById('symp-antibiotic').value.trim();
  const duration = document.getElementById('symp-duration').value;
  const location = document.getElementById('symp-location').value;

  if (!disease || !antibiotic) {
    document.getElementById('symp-disease').style.borderColor = !disease ? 'rgba(220,38,38,0.5)' : '';
    document.getElementById('symp-antibiotic').style.borderColor = !antibiotic ? 'rgba(220,38,38,0.5)' : '';
    setTimeout(() => {
      document.getElementById('symp-disease').style.borderColor = '';
      document.getElementById('symp-antibiotic').style.borderColor = '';
    }, 2000);
    return;
  }

  document.getElementById('sympResults').classList.remove('visible');
  document.getElementById('sympLoading').style.display = 'flex';

  setTimeout(() => {
    document.getElementById('sympLoading').style.display = 'none';
    const result = calcRisk(disease, antibiotic, rxSelected, duration, location);
    renderResults(result, disease, antibiotic);
    document.getElementById('sympResults').classList.add('visible');
    document.getElementById('sympResults').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }, 2200);
}

function calcRisk(disease, antibiotic, rx, duration, location) {
  const d = disease.toLowerCase();
  const a = antibiotic.toLowerCase();
  let score = 0;
  let factors = [];

  if (rx === 'no') { score += 35; factors.push({ label: 'Self-medication', val: 35, color: '#dc2626' }); }
  else { factors.push({ label: 'Has prescription', val: 5, color: '#16a34a' }); }

  const viral = ['cold','flu','fever','cough','viral','sore throat'].some(v => d.includes(v));
  if (viral) { score += 40; factors.push({ label: 'Antibiotic for viral illness', val: 40, color: '#dc2626' }); }

  const broadSpectrum = ['augmentin','azithromycin','ciprofloxacin','levofloxacin','meropenem','carbapenem'].some(x => a.includes(x));
  if (broadSpectrum) { score += 15; factors.push({ label: 'Broad-spectrum agent', val: 15, color: '#d97706' }); }
  else { factors.push({ label: 'Narrow-spectrum agent', val: 5, color: '#2563eb' }); }

  const dur = parseInt(duration) || 5;
  if (dur > 10) { score += 20; factors.push({ label: 'Extended duration (>10d)', val: 20, color: '#d97706' }); }
  else if (dur < 3) { score += 10; factors.push({ label: 'Under-treatment risk', val: 10, color: '#d97706' }); }

  const highRiskArea = location && (location.includes('Bengaluru') || location.includes('Mumbai') || location.includes('Delhi'));
  if (highRiskArea) { score += 10; factors.push({ label: 'High-AMR region', val: 10, color: '#d97706' }); }

  score = Math.min(score, 100);
  const level = score >= 65 ? 'high' : score >= 35 ? 'medium' : 'low';
  return { score, level, factors, viral, rx, broadSpectrum };
}

function renderResults(result, disease, antibiotic) {
  const riskMessages = {
    high: { title: 'High Resistance Risk Detected', desc: `The combination of ${disease} and ${antibiotic} usage pattern shows significant risk factors for antimicrobial resistance. Immediate clinical review is recommended.` },
    medium: { title: 'Moderate Resistance Risk', desc: `Your antibiotic usage for ${disease} has some concerning patterns. While not immediately alarming, adjustments to usage practices are advisable.` },
    low: { title: 'Low Resistance Risk', desc: `Your antibiotic usage appears appropriate for ${disease}. Continue to complete the full course as prescribed and avoid future self-medication.` }
  };

  const icons = {
    high: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
    medium: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
    low: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`
  };

  const scoreColor = result.level === 'high' ? '#dc2626' : result.level === 'medium' ? '#b45309' : '#16a34a';
  const msg = riskMessages[result.level];
  document.getElementById('riskCard').innerHTML = `
    <div class="result-risk-card ${result.level} fade-up">
      <div class="risk-icon">${icons[result.level]}</div>
      <div class="risk-info">
        <h3>${msg.title}</h3>
        <p>${msg.desc}</p>
      </div>
      <div style="margin-left:auto;text-align:right;flex-shrink:0">
        <div style="font-size:26px;font-weight:700;font-family:var(--mono);color:${scoreColor}">${result.score}</div>
        <div style="font-size:11px;color:var(--lt-text3)">Risk Score</div>
      </div>
    </div>`;

  if (chartInstance) { chartInstance.destroy(); }
  const factors = result.factors.slice(0, 5);
  const ctx = document.getElementById('riskChart').getContext('2d');
  chartInstance = new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels: factors.map(f => f.label),
      datasets: [{ data: factors.map(f => f.val), backgroundColor: factors.map(f => f.color + 'cc'), borderColor: factors.map(f => f.color), borderWidth: 1.5, hoverOffset: 6 }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      cutout: '65%',
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => ` ${ctx.label}: ${ctx.parsed}%` } } }
    }
  });

  let legendHTML = '';
  factors.forEach(f => {
    legendHTML += `<div class="legend-item"><div class="legend-dot" style="background:${f.color}"></div><span class="legend-label">${f.label}</span><span class="legend-val">${f.val}%</span></div>`;
  });
  document.getElementById('chartLegend').innerHTML = legendHTML;

  const tips = [];
  if (result.rx === 'no') tips.push('Always consult a doctor before taking antibiotics.');
  if (result.viral) tips.push('Antibiotics do not work against viral infections — they only treat bacterial ones.');
  if (result.broadSpectrum) tips.push('Broad-spectrum antibiotics should be reserved for severe or resistant infections.');
  tips.push('Always complete the full course of antibiotics as prescribed, even if you feel better.');

  document.getElementById('sympExplanation').innerHTML = `
    <div class="lt-form-label" style="margin-bottom:12px;">AI Recommendations</div>
    ${tips.map(t => `<div style="display:flex;gap:10px;align-items:flex-start;margin-bottom:10px;font-size:13px;color:var(--lt-text2);line-height:1.6"><span style="color:var(--lt-accent);margin-top:2px;flex-shrink:0;font-weight:700">›</span>${t}</div>`).join('')}`;
}
</script>
