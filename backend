from flask import Flask, request, jsonify
from flask_cors import CORS
import google.generativeai as genai
import joblib
import pandas as pd
import os
from dotenv import load_dotenv
import json
import base64  

load_dotenv()
app = Flask(__name__)
CORS(app) 

genai.configure(api_key=os.getenv("GEMINI_API_KEY"))

gemini_model = genai.GenerativeModel(
    'gemini-2.5-flash',
    generation_config={"response_mime_type": "application/json"}
)

model = joblib.load('amr_model.pkl')
model_columns = joblib.load('model_columns.pkl')

@app.route('/analyze', methods=['POST'])
def analyze_prescription():
    try:
        data = request.json
        base64_image_url = data.get('image', '')
        user_symptom = data.get('symptom', 'Fever')
        user_age = int(data.get('age', 25))

        if not base64_image_url:
            return jsonify({"status": "error", "message": "No image was uploaded!"})

        prompt = """
        You are a medical assistant. Extract the main medicine name from this prescription.
        Match it exactly to 'Access', 'Watch', or 'Reserve' based on WHO guidelines.
        Return ONLY a JSON dictionary: {"medicine_name": "Name", "aware_category": "Category"}
        """

        mime_type = "image/jpeg"
        if "base64," in base64_image_url:
            header, pure_base64 = base64_image_url.split("base64,")
            mime_type = header.replace("data:", "").replace(";", "")
        else:
            pure_base64 = base64_image_url

        image_bytes = base64.b64decode(pure_base64)

        image_part = {
            "mime_type": mime_type,
            "data": image_bytes
        }
        
        response = gemini_model.generate_content([prompt, image_part])
        
        clean_text = response.text.replace('```json', '').replace('```', '').strip()
        agent_data = json.loads(clean_text)

        if isinstance(agent_data, list) and len(agent_data) > 0:
            agent_data = agent_data[0]
        elif isinstance(agent_data, list):
            agent_data = {}

        detected_med = agent_data.get("medicine_name", "Unknown")
        detected_category = agent_data.get("aware_category", "Access")

        is_unnecessary = 1 if user_symptom == "Viral Cold" or detected_category == "Reserve" else 0
        
        input_data = pd.DataFrame({
            'Age': [user_age], 'Symptom': [user_symptom],
            'Medicine': [detected_med], 'AWaRe_Category': [detected_category],
            'Is_Unnecessary': [is_unnecessary]
        })
        
        input_encoded = pd.get_dummies(input_data).reindex(columns=model_columns, fill_value=0)
        prediction = int(model.predict(input_encoded)[0])

        return jsonify({
            "status": "success",
            "medicine": detected_med,
            "category": detected_category,
            "risk_level": "HIGH RISK" if prediction == 1 else "LOW RISK"
        })

    except Exception as e:
        return jsonify({"status": "error", "message": f"PYTHON CRASH REPORT: {str(e)}"})

if __name__ == '__main__':
    app.run(port=5000, debug=True)
